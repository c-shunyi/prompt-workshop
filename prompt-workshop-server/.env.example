# 服务端口
PORT=3000

# 运行环境：development | production
NODE_ENV=development

# 数据库连接（MySQL 8.0）
DATABASE_URL="mysql://root:password@localhost:3306/prompt_workshop"

# JWT 配置
JWT_SECRET="your-jwt-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# JWT 管理台配置（可与客户端共用，也可独立配置）
JWT_ADMIN_SECRET="your-admin-jwt-secret-key-change-in-production"
JWT_ADMIN_EXPIRES_IN="1d"
